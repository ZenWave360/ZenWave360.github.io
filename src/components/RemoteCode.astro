---
import cache from '../remote-code-cache.json';
import {
  customShikiLangAlias,
} from '../utils/code-highlighting';
import { renderExpressiveCode } from '../utils/expressive-code';
import SourceIcon from './SourceIcon.astro';

interface Props {
  url?: string;
  language?: string;
  content?: string;
  visibleRange?: string;
  showLegend?: boolean;
  title?: string;
  summary?: string;
  collapsed?: boolean;
}

const {
  url,
  language,
  content = '',
  visibleRange,
  showLegend = true,
  title,
  summary,
  collapsed = false,
} = Astro.props;

function transformGitHubUrl(inputUrl?: string) {
  if (!inputUrl) return inputUrl;
  const match = inputUrl.match(/^https:\/\/github\.com\/([^/]+)\/([^/]+)\/blob\/([^/]+)\/(.+)$/);
  if (!match) return inputUrl;
  const [, user, repo, branch, filePath] = match;
  return `https://raw.githubusercontent.com/${user}/${repo}/refs/heads/${branch}/${filePath}`;
}

function sourceUrl(inputUrl?: string) {
  if (!inputUrl) return undefined;
  if (!visibleRange) return inputUrl;
  const [start, end] = visibleRange.split(',').map((part) => Number(part.trim()));
  return `${inputUrl}#L${start}-L${end}`;
}

function resolveLanguage(requestedLanguage?: string, fallbackLanguage?: string) {
  const configuredLanguage = requestedLanguage?.trim() || fallbackLanguage?.trim() || 'plaintext';
  return customShikiLangAlias[configuredLanguage] || configuredLanguage;
}

function trimBlankEdgeLines(value: string) {
  return value
    .replace(/^(?:[ \t]*\r?\n)+/, '')
    .replace(/(?:\r?\n[ \t]*)+$/, '');
}

const label = title || summary;
const fetchUrl = transformGitHubUrl(url);
const sourceHref = sourceUrl(url);
const cacheKey = `${fetchUrl || ''}:${visibleRange || 'full'}`;
const cachedEntry = (cache as Record<string, { content: string; language?: string }>)[cacheKey];
const cached = cachedEntry?.content;
const rawDisplayContent = content || cached || `Remote code snapshot missing for ${cacheKey}. Run npm run sync:remote-code.`;
const displayContent = trimBlankEdgeLines(rawDisplayContent);
const resolvedLanguage = resolveLanguage(language, cachedEntry?.language);
let highlightedCode: string | undefined;
let sharedStyles: string | undefined;
let blockStyles: string | undefined;
let blockScripts: string | undefined;

const rendered = await renderExpressiveCode({
  code: displayContent,
  language: resolvedLanguage,
});
highlightedCode = rendered.html;
blockStyles = rendered.blockStyles;

const locals = Astro.locals as Record<string, unknown>;
if (!locals.__ecStylesEmitted) {
  locals.__ecStylesEmitted = true;
  sharedStyles = rendered.sharedStyles;
  blockScripts = rendered.scripts;
}
---

<div class="remote-code not-content">
  {sharedStyles && <style is:inline set:html={sharedStyles} />}
  {blockScripts && <script type="module" is:inline set:html={blockScripts} />}
  {blockStyles && <style is:inline set:html={blockStyles} />}
  {label ? (
    collapsed ? (
      <details data-lazy-code>
        <summary>
          <span class="remote-code__title">
            <span class="remote-code__caret" aria-hidden="true"></span>
            <span class="remote-code__label">{label}</span>
          </span>
          {showLegend && sourceHref && (
            <a
              class="remote-code__source-action"
              href={sourceHref}
              target="_blank"
              rel="noreferrer"
              aria-label="Navigate to source"
              title="Navigate to source"
              onclick="event.stopPropagation()"
            >
              <SourceIcon class="remote-code__source-action-icon" />
            </a>
          )}
        </summary>
        <template class="remote-code__lazy-content">
          <Fragment set:html={highlightedCode} />
        </template>
      </details>
    ) : (
      <details open>
        <summary>
          <span class="remote-code__title">
            <span class="remote-code__caret" aria-hidden="true"></span>
            <span class="remote-code__label">{label}</span>
          </span>
          {showLegend && sourceHref && (
            <a
              class="remote-code__source-action"
              href={sourceHref}
              target="_blank"
              rel="noreferrer"
              aria-label="Navigate to source"
              title="Navigate to source"
              onclick="event.stopPropagation()"
            >
              <SourceIcon class="remote-code__source-action-icon" />
            </a>
          )}
        </summary>
        <Fragment set:html={highlightedCode} />
      </details>
    )
  ) : (
    <Fragment set:html={highlightedCode} />
  )}
  {showLegend && sourceHref && <p class="remote-code__source"><a href={sourceHref} target="_blank" rel="noreferrer">Navigate to source</a></p>}
</div>

<script>
  function initLazyRemoteCode() {
    document.querySelectorAll('details[data-lazy-code]').forEach(details => {
      if (details.dataset.lazyCodeBound === 'true') return;
      details.dataset.lazyCodeBound = 'true';
      const handler = () => {
        if (details.open) {
          const template = details.querySelector('template.remote-code__lazy-content');
          if (template) {
            details.insertBefore(template.content, template);
            template.remove();
          }
          details.removeAttribute('data-lazy-code');
          delete details.dataset.lazyCodeBound;
          details.removeEventListener('toggle', handler);
        }
      };
      details.addEventListener('toggle', handler);
    });
  }
  initLazyRemoteCode();
  document.addEventListener('astro:page-load', initLazyRemoteCode);
</script>
