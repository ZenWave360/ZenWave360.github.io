---
import discoverImg from '../assets/images/platform/lifecycle/business-events-whiteboard.webp';
import discoverIcon1 from '../assets/images/platform/lifecycle/domain-expert-icon.svg?url';
import discoverIcon2 from '../assets/images/platform/lifecycle/engineer-icon.svg?url';
import generateIcon1 from '../assets/images/platform/lifecycle/zenwave-icon-document.svg?url';
import generateIcon2 from '../assets/images/platform/lifecycle/zenwave-icon-services.svg?url';
import generateIcon3 from '../assets/images/platform/lifecycle/zenwave-icon-check.svg?url';
import generateIcon4 from '../assets/images/platform/lifecycle/zenwave-icon-cube.svg?url';
import navigateIcon1 from '../assets/images/platform/lifecycle/human-icon-80-green.svg?url';
import navigateIcon2 from '../assets/images/platform/lifecycle/tool-icon-80-green.svg?url';
import navigateIcon3 from '../assets/images/platform/lifecycle/ai-icon-80-green.svg?url';
import navigateImg from '../assets/images/platform/lifecycle/navigate-ide.webp';
import shapeImg from '../assets/images/platform/lifecycle/shape.webp';
import generateImg from '../assets/images/platform/lifecycle/generate-implement-spring-boot.webp';

const stages = [
  {
    title: 'Discover',
    tone: 'teal',
    legend: ['Domain Experts', 'Engineers'],
    icons: [
      { src: discoverIcon1, alt: 'Domain expert' },
      { src: discoverIcon2, alt: 'Engineer' },
    ],
  },
  {
    title: 'Shape',
    tone: 'blue',
    legend: ['Workflows', 'Domain Model', 'OpenAPI', 'AsyncAPI'],
    icons: [
      { src: '/images/platform/icons/zfl-icon.png', alt: 'ZFL business flow language' },
      { src: '/images/platform/icons/zdl-icon.png', alt: 'ZDL domain modeling language' },
      { src: '/logos/openapi-logo.svg', alt: 'OpenAPI' },
      { src: '/logos/asyncapi-logo.png', alt: 'AsyncAPI' },
    ],
  },
  {
    title: 'Generate & Implement',
    tone: 'amber',
    legend: ['APIs', 'Services', 'Tests', 'Infra'],
    icons: [
      { src: generateIcon1, alt: 'Generate APIs and events' },
      { src: generateIcon2, alt: 'Scaffold services' },
      { src: generateIcon3, alt: 'Tests' },
      { src: generateIcon4, alt: 'Build and deliver' },
    ],
  },
  {
    title: 'Navigate',
    tone: 'green',
    legend: ['Humans Explore', 'Tools Connect', 'AI Understands'],
    icons: [
      { src: navigateIcon1, alt: 'Humans explore' },
      { src: navigateIcon2, alt: 'Tools connect' },
      { src: navigateIcon3, alt: 'AI understands' },
    ],
  },
];
---

<section class="architecture-band" aria-labelledby="architecture-band-title">
  <div class="architecture-band__shell">
    <div class="architecture-band__heading">
      <p>SHARED CONTEXT</p>
      <h2 id="architecture-band-title">Humans Explore, Tools Connect, AI Understands</h2>
      <p>
        ZenWave makes architecture readable by people, traversable by tools, and usable as context
        for AI-assisted delivery.
      </p>
    </div>

    <ol class="architecture-band__stages">
      {
        stages.map((stage, index) => (
          <li class={`architecture-stage architecture-stage--${stage.tone}`}>
            <article>
              <div class="architecture-stage__top">
                <span class="architecture-stage__dot" aria-hidden="true">
                  {stage.title === 'Discover' && (
                    <svg viewBox="0 0 64 64">
                      <circle cx="28" cy="28" r="15" />
                      <path d="m39 39 11 11" />
                      <path d="M22 28c0-4 3-7 7-7" />
                    </svg>
                  )}
                  {stage.title === 'Shape' && (
                    <svg viewBox="0 0 64 64">
                      <circle cx="32" cy="14" r="6" />
                      <circle cx="17" cy="42" r="6" />
                      <circle cx="47" cy="42" r="6" />
                      <path d="M29 19 20 37" />
                      <path d="M35 19 44 37" />
                      <path d="M23 42h18" />
                    </svg>
                  )}
                  {stage.title === 'Generate & Implement' && (
                    <svg viewBox="0 0 64 64">
                      <path d="m25 20-12 12 12 12" />
                      <path d="m39 20 12 12-12 12" />
                      <path d="m36 16-8 32" />
                    </svg>
                  )}
                  {stage.title === 'Navigate' && (
                    <svg viewBox="0 0 64 64">
                      <circle cx="32" cy="32" r="22" />
                      <path d="m42 22-7 20-17 4 7-20 17-4Z" />
                      <circle cx="32" cy="32" r="3" />
                    </svg>
                  )}
                </span>
                {index < stages.length - 1 && <span class="architecture-stage__arrow" aria-hidden="true" />}
              </div>

              <h3>{stage.title}</h3>

              <div class="architecture-stage__visual" aria-hidden="true">
                {stage.title === 'Discover' && (
                  <img src={discoverImg.src} alt="Business Events whiteboard with sticky notes" width={discoverImg.width} height={discoverImg.height} loading="lazy" decoding="async" />
                )}

                {stage.title === 'Shape' && (
                  <img src={shapeImg.src} alt="ZenWave architecture shape diagram with bounded contexts and domain model" width={shapeImg.width} height={shapeImg.height} loading="lazy" decoding="async" />
                )}

                {stage.title === 'Generate & Implement' && (
                  <img src={generateImg.src} alt="ZenWave SDK generated Spring Boot service code in IDE" width={generateImg.width} height={generateImg.height} loading="lazy" decoding="async" />
                )}

                {stage.title === 'Navigate' && (
                  <img src={navigateImg.src} alt="ZenWave IntelliJ plugin IDE navigation view" width={navigateImg.width} height={navigateImg.height} loading="lazy" decoding="async" />
                )}
              </div>

              <ul
                class={`architecture-stage__legend${stage.icons ? ' architecture-stage__legend--icons' : ''}`}
                style={`--legend-count: ${stage.legend.length}`}
                aria-label={`${stage.title} artifacts`}
              >
                {stage.legend.map((item, i) => (
                  <li>
                    {stage.icons && (
                      <img src={stage.icons[i].src} alt={stage.icons[i].alt} width="40" height="40" loading="lazy" decoding="async" />
                    )}
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </article>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .architecture-band {
    --band-bg: var(--home-bg, #111318);
    --band-panel: var(--home-panel, #151820);
    --band-panel-strong: var(--home-panel-strong, #191d25);
    --band-text: var(--home-text, #f3f5f8);
    --band-muted: var(--home-muted, #b9c0ca);
    --band-border: var(--home-border, #303744);
    --band-shadow: 0 1.1rem 2.2rem rgb(0 0 0 / 0.2);
    position: relative;
    padding: clamp(2rem, 3vw, 2.75rem) 0 clamp(1.4rem, 2.5vw, 2.2rem);
    border-top: 1px solid color-mix(in srgb, var(--band-border), transparent 30%);
    border-bottom: 1px solid color-mix(in srgb, var(--band-border), transparent 30%);
    background:
      linear-gradient(90deg, color-mix(in srgb, #14a39a 7%, transparent), transparent 40%),
      linear-gradient(270deg, color-mix(in srgb, #55a447 7%, transparent), transparent 42%),
      color-mix(in srgb, var(--band-panel), transparent 30%);
  }

  :root[data-theme='light'] .architecture-band {
    --band-shadow: 0 1rem 2rem rgb(32 41 58 / 0.1);
  }

  .architecture-band__shell {
    width: min(var(--home-shell-width, 1320px), calc(100% - clamp(2rem, 5vw, 4rem)));
    margin-inline: auto;
  }

  .architecture-band__heading {
    margin-bottom: 1.5rem;
  }

  .architecture-band__heading p {
    margin: 0;
    color: var(--band-muted);
    line-height: 1.58;
  }

  .architecture-band__heading p:first-child {
    margin-bottom: 0.6rem;
    color: var(--home-highlight, #ffe04b);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .architecture-band__heading p:last-child {
    max-width: 58rem;
  }

  .architecture-band__heading h2 {
    margin: 0 0 0.75rem;
    color: var(--band-text);
    font-size: clamp(1.55rem, 2.35vw, 2.05rem);
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: 0;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .architecture-band__stages {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.85rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .architecture-stage {
    --stage-accent: #14a39a;
    position: relative;
    min-width: 0;
  }

  .architecture-stage--teal {
    --stage-accent: #14a39a;
  }

  .architecture-stage--blue {
    --stage-accent: #3b75d1;
  }

  .architecture-stage--amber {
    --stage-accent: #d99100;
  }

  .architecture-stage--green {
    --stage-accent: #55a447;
  }

  .architecture-stage article {
    display: grid;
    grid-template-rows: auto 4.8rem auto auto;
    min-height: 0;
    padding: 0 0.8rem 0.8rem;
    border: 1px solid color-mix(in srgb, var(--band-border), transparent 10%);
    border-radius: 8px;
    background: color-mix(in srgb, var(--band-panel), transparent 8%);
    box-shadow: var(--band-shadow);
  }

  .architecture-stage:first-child article {
    border-radius: 8px;
  }

  .architecture-stage:last-child article {
    border-radius: 8px;
  }

  .architecture-stage__top {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 5.15rem;
  }

  .architecture-stage__top::before,
  .architecture-stage__top::after {
    content: '';
    position: absolute;
    top: 50%;
    height: 4px;
    transform: translateY(-50%);
    background: var(--stage-accent);
    opacity: 0.95;
  }

  .architecture-stage__top::before {
    left: 0;
    width: calc(50% - 2.55rem);
  }

  .architecture-stage__top::after {
    right: 0;
    width: calc(50% - 2.55rem);
  }

  .architecture-stage:first-child .architecture-stage__top::before,
  .architecture-stage:last-child .architecture-stage__top::after {
    background: color-mix(in srgb, var(--band-border), transparent 15%);
    width: calc(50% - 2.8rem);
  }

  .architecture-stage__dot {
    position: relative;
    z-index: 2;
    display: grid;
    place-items: center;
    width: 5rem;
    aspect-ratio: 1;
    border: 4px solid color-mix(in srgb, white 82%, var(--stage-accent));
    border-radius: 999px;
    background:
      radial-gradient(circle at 38% 34%, color-mix(in srgb, white 22%, transparent), transparent 42%),
      var(--stage-accent);
    box-shadow:
      0 0.4rem 1rem color-mix(in srgb, var(--stage-accent), transparent 55%),
      0 0 0 0.45rem color-mix(in srgb, var(--stage-accent) 16%, transparent);
  }

  .architecture-stage__dot svg {
    width: 2.6rem;
    height: 2.6rem;
    color: #fff;
  }

  .architecture-stage__dot :where(path, circle) {
    fill: none;
    stroke: currentColor;
    stroke-width: 5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .architecture-stage__arrow {
    position: absolute;
    top: 50%;
    right: -1.08rem;
    z-index: 3;
    width: 0;
    height: 0;
    border-top: 0.55rem solid transparent;
    border-bottom: 0.55rem solid transparent;
    border-left: 0.8rem solid var(--stage-accent);
    transform: translateY(-50%);
  }

  .architecture-stage h3 {
    margin: 0;
    align-self: center;
    color: var(--band-text);
    font-size: clamp(1.25rem, 1.75vw, 1.6rem);
    line-height: 1;
    text-align: center;
    letter-spacing: 0;
  }

  .architecture-stage__visual {
    display: grid;
    min-height: 16.5rem;
    overflow: hidden;
    border-radius: 8px;
    background: transparent;
  }

  .architecture-stage__visual svg,
  .architecture-stage__visual img {
    width: 100%;
    height: 100%;
    min-height: 16.5rem;
  }

  .architecture-stage__visual img {
    object-fit: contain;
    object-position: center top;
  }

  .architecture-stage__visual text {
    fill: var(--band-text);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 12px;
    font-weight: 700;
  }

  .architecture-stage__visual .muted-label,
  .architecture-stage__visual .lane-labels text,
  .architecture-stage__visual .folder-list text,
  .architecture-stage__visual .row-label {
    fill: var(--band-muted);
    font-size: 8px;
    font-weight: 600;
  }

  .window,
  .domain-panel,
  .app-window {
    fill: color-mix(in srgb, var(--band-panel), white 3%);
    stroke: color-mix(in srgb, var(--band-border), white 10%);
  }

  .rail,
  .editor-top,
  .app-top {
    fill: color-mix(in srgb, var(--band-border), white 16%);
  }

  .flow-line,
  .shape-line,
  .map-link,
  .model-link {
    fill: none;
    stroke: color-mix(in srgb, #8ab9df, var(--band-text) 25%);
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .dashed,
  .map-link {
    stroke-dasharray: 6 5;
  }

  .note {
    stroke: color-mix(in srgb, #000, transparent 82%);
  }

  .note--domain,
  .note--yellow {
    fill: #ffd65a;
  }

  .note--teal {
    fill: #8bd8d0;
  }

  .note--pink {
    fill: #ff9ea8;
  }

  .skin {
    fill: #c99063;
  }

  .hair {
    fill: #3b2b24;
  }

  .hair--dark {
    fill: #222830;
  }

  .person--left,
  .person--right {
    fill: #1d9389;
  }

  .person--middle {
    fill: #252b31;
  }

  .grid-bg path {
    fill: none;
    stroke: color-mix(in srgb, var(--band-border), transparent 70%);
    stroke-width: 1;
  }

  .boundary {
    fill: none;
    stroke: #14a39a;
    stroke-width: 1.7;
    stroke-dasharray: 7 5;
  }

  .context,
  .service--core {
    fill: #14a39a;
    stroke: color-mix(in srgb, #14a39a, white 28%);
  }

  .white-label {
    fill: #fff !important;
  }

  .domain-panel {
    filter: drop-shadow(0 8px 12px rgb(0 0 0 / 0.15));
  }

  .model-block {
    fill: #a9d59d;
    stroke: #6aa45e;
  }

  .contexts rect,
  .service--blue {
    fill: #dbeeff;
    stroke: #5f9dea;
  }

  .contexts text,
  .service-map text {
    fill: #0d1420;
  }

  .anchor {
    fill: color-mix(in srgb, var(--band-panel), white 22%);
    stroke: color-mix(in srgb, #3b75d1, white 20%);
    stroke-width: 1.5;
  }

  .editor {
    fill: #111923;
    stroke: #2d3846;
  }

  .sidebar,
  .nav-rail {
    fill: #17212c;
  }

  .dot-red {
    fill: #ef6a61;
  }

  .dot-amber {
    fill: #f5b642;
  }

  .dot-green {
    fill: #72c96a;
  }

  .folder-list text {
    fill: #d9e3ed !important;
  }

  .code text {
    fill: #e8edf4;
    font-family: Consolas, "Courier New", monospace;
    font-size: 9px;
    font-weight: 500;
  }

  .code text:nth-child(1),
  .code text:nth-child(8) {
    fill: #80d7c9;
  }

  .pipeline-bg {
    fill: color-mix(in srgb, #fff7e5, var(--band-panel) 15%);
  }

  :root:not([data-theme='light']) .pipeline-bg {
    fill: color-mix(in srgb, #614a16, var(--band-panel) 65%);
  }

  .pipeline circle {
    fill: #55a447;
    stroke: #f0f7ed;
    stroke-width: 3;
  }

  .pipeline path {
    fill: none;
    stroke: #fff;
    stroke-width: 3;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .pipeline .pipeline-arrow {
    stroke: color-mix(in srgb, var(--band-muted), #1f2b36 35%);
    stroke-width: 2;
  }

  .app-window {
    fill: #f8fafc;
  }

  :root:not([data-theme='light']) .app-window {
    fill: #e9eef3;
  }

  .nav-panel {
    fill: #f2f6f8;
  }

  .app-label,
  .row-label,
  .muted-label {
    fill: #111827 !important;
  }

  .search {
    fill: #ffffff;
    stroke: #d4dce3;
  }

  .selected-row {
    fill: #c8eee9;
  }

  .service {
    filter: drop-shadow(0 5px 9px rgb(0 0 0 / 0.18));
  }

  .service--purple {
    fill: #dfdbff;
    stroke: #8c84e8;
  }

  .architecture-stage__legend {
    display: grid;
    grid-template-columns: repeat(var(--legend-count, 3), minmax(0, 1fr));
    gap: 1px;
    min-height: 5.1rem;
    margin: 0.8rem 0 0;
    padding: 0;
    overflow: hidden;
    border-radius: 8px;
    background: color-mix(in srgb, var(--stage-accent) 18%, var(--band-panel));
    list-style: none;
  }

  .architecture-stage__legend li {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    padding: 0.55rem 0.35rem;
    border-left: 1px solid color-mix(in srgb, var(--band-border), transparent 35%);
    color: var(--band-text);
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.15;
    text-align: center;
  }

  .architecture-stage__legend li:first-child {
    border-left: 0;
  }

  .architecture-stage__legend li::before {
    content: '';
    flex: 0 0 auto;
    width: 1.65rem;
    height: 1.65rem;
    margin-right: 0.4rem;
    background: var(--stage-accent);
    mask: radial-gradient(circle at 50% 50%, #000 36%, transparent 38%);
    opacity: 0.95;
  }

  .architecture-stage__legend li:nth-child(2)::before {
    mask:
      linear-gradient(#000 0 0) center / 70% 18% no-repeat,
      linear-gradient(#000 0 0) center / 18% 70% no-repeat;
  }

  .architecture-stage__legend li:nth-child(3)::before {
    mask:
      linear-gradient(#000 0 0) left 0 bottom 0 / 18% 45% no-repeat,
      linear-gradient(#000 0 0) center bottom / 18% 70% no-repeat,
      linear-gradient(#000 0 0) right 0 bottom 0 / 18% 92% no-repeat;
  }

  .architecture-stage__legend li:nth-child(4)::before {
    mask:
      linear-gradient(#000 0 0) left 0 center / 40% 16% no-repeat,
      linear-gradient(#000 0 0) right 0 center / 40% 16% no-repeat,
      radial-gradient(circle at 50% 50%, transparent 36%, #000 38% 54%, transparent 56%);
  }

  .architecture-stage__legend--icons {
    min-height: 6rem;
  }

  .architecture-stage__legend--icons li {
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.65rem 0.3rem 0.55rem;
  }

  .architecture-stage__legend--icons li::before {
    display: none;
  }

  .architecture-stage__legend--icons img {
    width: 2.4rem;
    height: 2.4rem;
    object-fit: contain;
    flex-shrink: 0;
  }

  .architecture-stage__legend--icons span {
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 1.1;
    text-align: center;
  }

  @media (max-width: 1180px) {
    .architecture-band__stages {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .architecture-stage article,
    .architecture-stage:first-child article,
    .architecture-stage:last-child article {
      border-width: 1px;
      border-radius: 8px;
    }

    .architecture-stage__arrow {
      display: none;
    }
  }

  @media (max-width: 660px) {
    .architecture-band__shell {
      width: min(var(--home-shell-width, 1320px), calc(100% - 1rem));
    }

    .architecture-band__stages {
      grid-template-columns: 1fr;
    }

    .architecture-stage article {
      min-height: 0;
      padding-inline: 0.65rem;
    }

    .architecture-stage h3 {
      min-height: 0;
      margin-bottom: 0.9rem;
      font-size: 1.75rem;
    }

    .architecture-stage__visual,
    .architecture-stage__visual svg,
    .architecture-stage__visual img {
      min-height: 18rem;
    }

    .architecture-stage__legend {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .architecture-stage__legend li {
      min-height: 3rem;
      font-size: 0.82rem;
    }
  }
</style>
