---
type CarouselSlide = {
  src: string;
  caption: string;
  alt?: string;
  width?: number;
  height?: number;
};

type Props = {
  slides: CarouselSlide[];
  ariaLabel?: string;
};

const { slides, ariaLabel = 'Image carousel' } = Astro.props;
---

<div class="image-carousel-wrap" data-image-carousel-root>
  <button class="image-carousel-control image-carousel-control--prev" type="button" aria-label="Previous image" data-image-carousel-prev>
    <span aria-hidden="true">&#8592;</span>
  </button>
  <div class="image-carousel" aria-label={ariaLabel} data-image-carousel>
    {slides.map((slide, index) => (
      <figure class="image-carousel-slide">
        <img
          src={slide.src}
          alt={slide.alt ?? slide.caption}
          width={slide.width}
          height={slide.height}
          loading={index === 0 ? 'eager' : 'lazy'}
          decoding="async"
        />
        <figcaption>{slide.caption}</figcaption>
      </figure>
    ))}
  </div>
  <button class="image-carousel-control image-carousel-control--next" type="button" aria-label="Next image" data-image-carousel-next>
    <span aria-hidden="true">&#8594;</span>
  </button>
</div>

<style>
  .image-carousel-wrap {
    position: relative;
    margin-top: 1.2rem;
  }

  .image-carousel {
    display: grid;
    grid-auto-columns: minmax(100%, 1fr);
    grid-auto-flow: column;
    gap: 1rem;
    overflow-x: auto;
    overscroll-behavior-inline: contain;
    scroll-behavior: smooth;
    scroll-snap-type: inline mandatory;
    scrollbar-color: var(--home-highlight, var(--sl-color-accent, #ffde44)) transparent;
    padding-bottom: 0.35rem;
    cursor: pointer;
    user-select: none;
  }

  .image-carousel-slide {
    position: relative;
    min-width: 0;
    margin: 0;
    overflow: hidden;
    scroll-snap-align: start;
    border: 1px solid var(--home-border, var(--sl-color-gray-5, #2f3541));
    border-radius: 0.5rem;
    background: var(--home-panel, var(--sl-color-bg-nav, #171a21));
  }

  .image-carousel-slide img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 8.4;
    object-fit: contain;
    background: #0d1118;
  }

  .image-carousel-slide figcaption {
    position: absolute;
    inset-inline: 0;
    inset-block-end: 0;
    padding: 1.8rem 1.1rem 0.85rem;
    color: #fff8e5;
    background: linear-gradient(180deg, transparent, rgb(0 0 0 / 0.82));
    font-size: clamp(0.95rem, 1.6vw, 1.12rem);
    font-weight: 700;
    line-height: 1.25;
    text-shadow: 0 1px 2px rgb(0 0 0 / 0.72);
  }

  .image-carousel-control {
    position: absolute;
    top: 50%;
    z-index: 3;
    display: grid;
    place-items: center;
    width: 2.55rem;
    aspect-ratio: 1;
    border: 1px solid color-mix(in srgb, var(--home-highlight, #ffde44), var(--home-border, #2f3541) 35%);
    border-radius: 999px;
    background: color-mix(in srgb, var(--home-panel-strong, #11151d), transparent 8%);
    color: var(--home-highlight, #ffde44);
    font: inherit;
    font-size: 1.2rem;
    font-weight: 800;
    line-height: 1;
    box-shadow: 0 0.8rem 1.4rem rgb(0 0 0 / 0.26);
    transform: translateY(-50%);
    cursor: pointer;
  }

  .image-carousel-control--prev {
    left: 0.75rem;
  }

  .image-carousel-control--next {
    right: 0.75rem;
  }

  @media (max-width: 720px) {
    .image-carousel-control {
      width: 2.25rem;
    }
  }
</style>

<script is:inline>
  document.querySelectorAll('[data-image-carousel]').forEach((carousel) => {
    if (carousel.dataset.carouselReady === 'true') return;

    carousel.dataset.carouselReady = 'true';
    const root = carousel.closest('[data-image-carousel-root]');
    const previous = root?.querySelector('[data-image-carousel-prev]');
    const next = root?.querySelector('[data-image-carousel-next]');

    const scrollBySlide = (direction) => {
      carousel.scrollBy({
        left: direction * carousel.clientWidth,
        behavior: 'smooth',
      });
    };

    carousel.addEventListener('click', (event) => {
      const bounds = carousel.getBoundingClientRect();
      const direction = event.clientX < bounds.left + bounds.width / 2 ? -1 : 1;
      scrollBySlide(direction);
    });

    previous?.addEventListener('click', (event) => {
      event.stopPropagation();
      scrollBySlide(-1);
    });

    next?.addEventListener('click', (event) => {
      event.stopPropagation();
      scrollBySlide(1);
    });
  });
</script>
