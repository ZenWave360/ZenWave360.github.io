---
import config from 'virtual:starlight/user-config';
import Search from 'virtual:starlight/components/Search';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';
---

<div class="zen-header">
  <div class="zen-header__title">
    <a class="zen-brand" href="/">
      <img src="/images/zenwave-logo.svg" alt="" />
      <span>ZenWave Platform</span>
    </a>
  </div>
  <div class="zen-header__search print:hidden">
    {shouldRenderSearch && <Search />}
  </div>
  <nav class="zen-header__nav" aria-label="Primary">
    <a href="/docs/">Documentation</a>
    <a href="/zenwave-sdk/">SDK</a>
    <a href="/plugin/">Plugin</a>
    <a href="/blog/">Blog</a>
  </nav>
  <div class="zen-header__tools sl-hidden md:sl-flex print:hidden">
    <div class="zen-header__social">
      <a href="https://github.com/ZenWave360" aria-label="GitHub">
        <svg viewBox="0 0 16 16" aria-hidden="true">
          <path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.67 0 8.2c0 3.63 2.29 6.7 5.47 7.79.4.08.55-.18.55-.39v-1.38c-2.23.5-2.7-1.1-2.7-1.1-.36-.95-.89-1.2-.89-1.2-.73-.51.06-.5.06-.5.8.06 1.23.85 1.23.85.72 1.26 1.88.9 2.34.69.07-.53.28-.9.51-1.1-1.78-.21-3.65-.91-3.65-4.05 0-.9.31-1.63.83-2.2-.08-.21-.36-1.04.08-2.17 0 0 .67-.22 2.2.84A7.45 7.45 0 0 1 8 4.01c.68 0 1.36.09 2 .27 1.52-1.06 2.19-.84 2.19-.84.44 1.13.16 1.96.08 2.17.52.57.83 1.3.83 2.2 0 3.15-1.88 3.84-3.67 4.04.29.26.54.76.54 1.53v2.27c0 .22.15.47.55.39A8.12 8.12 0 0 0 16 8.2C16 3.67 12.42 0 8 0Z"
          />
        </svg>
      </a>
      <a href="https://discord.gg/TWyXEeV2Ae" aria-label="Discord">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill="currentColor"
            d="M20.32 4.37A19.8 19.8 0 0 0 15.36 3c-.22.39-.47.92-.64 1.33a18.4 18.4 0 0 0-5.44 0A14.6 14.6 0 0 0 8.64 3c-1.73.3-3.4.77-4.96 1.37C.55 9.14-.3 13.79.13 18.37a19.9 19.9 0 0 0 6.08 3.11c.49-.68.93-1.4 1.3-2.17a12.9 12.9 0 0 1-2.05-1c.17-.13.34-.26.5-.4a14.2 14.2 0 0 0 12.08 0c.17.14.33.27.5.4-.65.39-1.34.73-2.06 1 .38.77.82 1.5 1.31 2.17a19.8 19.8 0 0 0 6.08-3.11c.5-5.31-.85-9.92-3.55-14ZM8.02 15.55c-1.18 0-2.15-1.1-2.15-2.44s.95-2.44 2.15-2.44 2.17 1.1 2.15 2.44c0 1.34-.95 2.44-2.15 2.44Zm7.96 0c-1.18 0-2.15-1.1-2.15-2.44s.95-2.44 2.15-2.44 2.17 1.1 2.15 2.44c0 1.34-.95 2.44-2.15 2.44Z"
          />
        </svg>
      </a>
    </div>
    <ThemeSelect />
  </div>
</div>

<style>
  @layer starlight.core {
    .zen-header {
      height: 100%;
      width: 100%;
      min-width: 0;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(14rem, 24rem) auto auto;
      align-items: center;
      gap: var(--sl-nav-gap, 1rem);
    }

    .zen-header__title {
      min-width: 0;
      display: flex;
      align-items: center;
    }

    .zen-brand {
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      min-width: 0;
      color: var(--sl-color-white);
      font-size: 1.25rem;
      font-weight: 500;
      line-height: 1;
      text-decoration: none;
    }

    .zen-brand img {
      max-height: 2.05rem;
      width: auto;
    }

    .zen-header__nav {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 1.1rem;
      min-width: 0;
      white-space: nowrap;
    }

    .zen-header__nav a {
      color: var(--sl-color-white);
      font-size: var(--sl-text-base);
      font-weight: 500;
      text-decoration: none;
    }

    .zen-header__nav a:hover {
      color: var(--sl-color-text-accent);
    }

    .zen-header__search {
      display: flex;
      justify-content: center;
      min-width: 0;
    }

    .zen-header__search :global(.pagefind-ui) {
      width: 100%;
    }

    .zen-header__tools {
      align-items: center;
      gap: 1rem;
      min-width: max-content;
    }

    .zen-header__social {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .zen-header__social::after {
      content: '';
      height: 2rem;
      border-inline-end: 1px solid var(--sl-color-gray-5);
    }

    .zen-header__tools :global(button) {
      color: var(--sl-color-white);
    }

    .zen-header__social a {
      color: var(--sl-color-white);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.5rem;
      height: 1.5rem;
      padding: 0;
      margin: 0;
    }

    .zen-header__social a:hover {
      color: var(--sl-color-text-accent);
    }

    .zen-header__social svg {
      width: 1rem;
      height: 1rem;
      display: block;
    }

    @media (max-width: 68rem) {
      .zen-header {
        grid-template-columns: auto minmax(8rem, 1fr) auto;
      }

      .zen-header__nav {
        display: none;
      }

      .zen-header__search {
        justify-content: stretch;
      }
    }
  }
</style>
