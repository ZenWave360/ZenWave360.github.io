---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const tagSlug = (tag) => tag.toLowerCase().replaceAll(' ', '-');
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const tags = new Set(posts.flatMap((post) => post.data.tags.map(tagSlug)));
  return Array.from(tags).map((tag) => ({
    params: { tag },
    props: { tag, posts: posts.filter((post) => post.data.tags.some((postTag) => tagSlug(postTag) === tag)) },
  }));
}

const { tag, posts } = Astro.props;
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BlogLayout title={`Tag: ${tag}`} description={`ZenWave 360 articles tagged ${tag}.`}>
  <main class="tag">
    <h1>#{tag}</h1>
    <section>
      {sortedPosts.map((post) => (
        <article>
          <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          <h2><a href={`/${post.id}/`}>{post.data.title}</a></h2>
          {(post.data.excerpt || post.data.description) && <p>{post.data.excerpt || post.data.description}</p>}
        </article>
      ))}
    </section>
  </main>
</BlogLayout>

<style>
  .tag {
    width: min(920px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 4rem 0;
  }

  h1 {
    font-size: clamp(2.25rem, 6vw, 4rem);
  }

  section {
    display: grid;
    gap: 1rem;
  }

  article {
    padding: 1.25rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--panel);
  }

  time,
  p {
    color: var(--muted);
  }
</style>
