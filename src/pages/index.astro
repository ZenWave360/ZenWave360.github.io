---
import ArchitectureLifecycleBand from '../components/ArchitectureLifecycleBand.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
import ZenFooter from '../components/ZenFooter.astro';
import ZenThemeProvider from '../components/ZenThemeProvider.astro';
import ZenTopBar from '../components/ZenTopBar.astro';
import '../styles/zenwave.css';

const platformScreenshots = [
  {
    file: 'zfl-flow.png',
    caption: 'Business flow modeled from Event Storming sessions',
    width: 1920,
    height: 1032,
  },
  {
    file: 'zfl-systems.png',
    caption: 'Systems map generated from a business flow',
    width: 1920,
    height: 1032,
  },
  {
    file: 'zfl-flowchart-diagram.png',
    caption: 'Flowchart visualization generated from ZFL',
    width: 1920,
    height: 1032,
  },
  {
    file: 'zfl-sequence-diagram.png',
    caption: 'Sequence diagrams derived from business flows',
    width: 1920,
    height: 1032,
  },
  {
    file: 'zdl-domain-model-with-preview.png',
    caption: 'Domain model with aggregates, entities and lifecycle states',
    width: 1920,
    height: 1032,
  },
  {
    file: 'zdl-openapi.png',
    caption: 'OpenAPI contracts derived from annotated service commands',
    width: 1920,
    height: 1032,
  },
  {
    file: 'zdl-asyncapi-plugin.png',
    caption: 'AsyncAPI contracts generated from domain events',
    width: 1920,
    height: 1032,
  },
];

const featuredCapabilities = [
  {
    variant: 'world-model',
    title: 'ZenWave Platform: Architecture World Model',
    badge: 'Building in public',
    text: 'An IDE experience for designing, navigating, and connecting domain models, business flows, APIs, source code, local folders, Git repositories, and schema registries with Apicurio.',
    note: 'The big picture of your software made explicit, connected, and navigable.',
    visual: 'world-model',
  },
  {
    variant: 'sdk',
    title: 'ZenWave SDK',
    badge: 'Production ready, evolving',
    image: '/images/laptop-buddha-transparent.png',
    imageAlt: '',
    imageWidth: 958,
    imageHeight: 1045,
    text: 'An ever-growing set of plugins that generate Spring Boot services, APIs, tests, event adapters, and infrastructure from connected architecture artifacts.',
    ctas: [
      {
        href: '/docs/zenwave-sdk/',
        label: 'ZenWave SDK',
      },
      {
        href: '/zenwave-sdk/',
        label: 'Explore plugins',
      },
    ],
  },
];

const platformCapabilityCards = [
  {
    title: 'AsyncAPI and Avro Generator',
    badge: 'Production ready',
    image: '/logos/asyncapi-logo.png',
    imageWidth: 280,
    imageHeight: 280,
    text: 'Generates strongly typed Spring Kafka and Spring Cloud Stream producers and consumers from AsyncAPI specifications.',
    href: '/zenwave-sdk/plugins/asyncapi-generator/',
  },
  {
    title: 'ZDL Modeling Language',
    badge: 'Production ready',
    image: '/images/platform/icons/zdl-icon.png',
    imageWidth: 286,
    imageHeight: 188,
    text: 'Model bounded contexts, entities, aggregates, commands, events, and services as structured domain artifacts.',
    href: '/docs/event-driven-design/zenwave-domain-language/',
  },
  {
    title: 'ZFL Flow Language',
    badge: 'Building in public',
    image: '/images/platform/icons/zfl-icon.png',
    imageWidth: 464,
    imageHeight: 336,
    text: 'Model business flows as policies that connect commands and events, then link them to APIs, schemas, and domain models.',
    href: '/docs/event-driven-design/zenwave-flow-language/',
  },
  {
    title: 'ZenWave IDE & MCP',
    badge: 'Building in public',
    image: '/images/platform/icons/zenwave-logo.svg',
    imageWidth: 756,
    imageHeight: 674,
    text: 'Architecture navigation and context for IDEs and AI agents. Powered by a Kotlin Multiplatform LSP server, with IntelliJ first, VS Code next, and MCP support for agent workflows.',
    href: '/plugin/',
  },
];

const supportingCapabilityIcons: Record<string, string> = {
  list: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round">
    <path d="M14 15h24" />
    <path d="M14 24h24" />
    <path d="M14 33h24" />
    <path d="M8 15h.01" />
    <path d="M8 24h.01" />
    <path d="M8 33h.01" />
  </svg>`,
  strategy: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round">
    <rect x="6" y="8" width="10" height="10" rx="2" />
    <rect x="32" y="8" width="10" height="10" rx="2" />
    <rect x="19" y="30" width="10" height="10" rx="2" />
    <path d="M16 13h16" />
    <path d="M24 18v12" />
    <path d="M11 18v8c0 4 3 7 8 7" />
    <path d="M37 18v8c0 4-3 7-8 7" />
  </svg>`,
  'paper-plane': `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round">
    <path d="M42 7 6 23l15 5 5 15L42 7Z" />
    <path d="m21 28 9-9" />
  </svg>`,
  schema: `<svg viewBox="0 0 48 48" class="schema-mark" fill="none" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round">
    <path d="M18 12c-5 0-7 3-7 7v3c0 2-1 3-3 3 2 0 3 1 3 3v3c0 4 2 7 7 7" />
    <path d="M30 12c5 0 7 3 7 7v3c0 2 1 3 3 3-2 0-3 1-3 3v3c0 4-2 7-7 7" />
  </svg>`,
};

const supportingCapabilityCards = [
  {
    title: 'EventCatalog Generator',
    badge: 'Coming soon',
    icon: 'list',
    text: 'Export OpenAPI, AsyncAPI, and ZenWave models to EventCatalog, or import existing EventCatalog documentation back into the ZenWave world model.',
  },
  {
    title: 'Terraform / asyncapi-ops',
    badge: 'Beta',
    icon: 'strategy',
    text: 'Provision Kafka topics, ACLs, and Schema Registry infrastructure from AsyncAPI contracts.',
    href: '/zenwave-sdk/plugins/asyncapi-ops/',
  },
  {
    title: 'Spring Modulith Events',
    badge: 'Production ready',
    icon: 'paper-plane',
    text: 'Externalize Spring Modulith domain events through Spring Cloud Stream. Used by the AsyncAPI Generator for Transactional Outbox integration.',
    href: 'https://github.com/ZenWave360/spring-modulith-events-spring-cloud-stream',
  },
  {
    title: 'JSON Schema Parser',
    badge: 'Supporting OSS',
    icon: 'schema',
    text: 'Standalone JSON Schema reference parsers for JVM and Kotlin Multiplatform, used across ZenWave SDK, the IntelliJ plugin, and other tooling.',
    href: 'https://github.com/ZenWave360/json-schema-ref-parser-kmp',
  },
];

const maturityBadgeClass = (badge: string) => {
  const label = badge.toLowerCase();

  if (label.startsWith('production ready')) {
    return 'maturity-badge--production';
  }

  if (label === 'building in public') {
    return 'maturity-badge--building';
  }

  if (label === 'beta' || label === 'coming soon') {
    return 'maturity-badge--emerging';
  }

  if (label === 'supporting oss') {
    return 'maturity-badge--supporting';
  }

  return '';
};

const referenceCards = [
  {
    title: 'AsyncAPI Shopping Cart',
    image: '/images/reference-architectures/ShoppingCartAsyncAPI.png',
    imageWidth: 260,
    imageHeight: 147,
    text: 'Define AsyncAPI and Avro contracts, then derive Kafka producers and consumers for a multi-module event-driven application.',
    href: '/docs/examples/eda-examples/asyncapi-shopping-cart/',
    cta: 'Follow the tutorial',
  },
  {
    title: 'Order Fulfillment Kotlin',
    image: '/images/reference-architectures/OrderFulfillmentKotlin.png',
    imageWidth: 260,
    imageHeight: 139,
    text: 'Capture ubiquitous language in ZDL and derive a Kotlin Spring Boot service with REST APIs, domain events, and generated implementation.',
    href: '/docs/examples/ddd-examples/order-fullillment-kotlin/',
    cta: 'Follow the tutorial',
  },
  {
    title: 'Transactional Outbox',
    image: '/images/reference-architectures/TransactionalOutBoxWithAsyncAPIAndSpringModulith.png',
    imageWidth: 1620,
    imageHeight: 1165,
    text: 'Implement the transactional outbox pattern with AsyncAPI, Spring Cloud Stream, Spring Modulith, and ZenWave SDK generation.',
    href: '/posts/TransactionalOutBoxWithAsyncAPIAndSpringModulith/',
    cta: 'Follow the tutorial',
  },
  {
    title: 'Clinical Tool Modulith',
    image: '/images/reference-architectures/ClinicalToolModulith.png',
    imageWidth: 260,
    imageHeight: 129,
    text: 'Model multiple bounded contexts and derive a modular monolith where domain boundaries, APIs, and persistence stay aligned.',
    href: '/docs/examples/ddd-examples/modulith-clinical-tool-jpa/',
    cta: 'Follow the tutorial',
  },
];

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ZenWave Platform</title>
    <meta
      name="description"
      content="ZenWave Platform makes the big picture of your software explicit, connected, and navigable for your team, your tools, and your AI agents."
    />
    <ZenThemeProvider />
  </head>
  <body>
    <ZenTopBar />

    <main>
      <section class="home-hero" aria-labelledby="hero-title">
        <div class="home-shell home-hero__grid">
          <div class="home-hero__copy">
            <p class="eyebrow">ZenWave Platform</p>
            <h1 id="hero-title">
              Understanding the big picture<br />
              is the only way to build,<br />
              maintain, and evolve<br />
              software with confidence.
            </h1>
            <p class="hero-lede">
              ZenWave Platform makes the big picture of your software explicit, connected, and
              navigable for your team, your tools, and your AI agents.
            </p>
            <div class="actions">
              <a class="button button--secondary" href="/docs/getting-started/">Get Started</a>
              <a class="button" href="#reference-title">See it in action</a>
            </div>
            <p class="status-line">Grounded in open standards. Built in public.</p>
          </div>

          <div class="home-hero__visual" aria-label="Architecture model map">
            <div class="model-map">
              <div class="model-map__header">
                <span>Architecture model</span>
                <span>Human + tools + AI</span>
              </div>
              <svg class="model-map__graph" viewBox="0 0 660 360" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
                <path d="M190,66 L248,146" />
                <path d="M330,78 L330,146" />
                <path d="M470,66 L412,146" />
                <path d="M190,178 L248,178" />
                <path d="M470,178 L412,178" />
                <path d="M190,294 L248,216" />
                <path d="M330,282 L330,216" />
                <path d="M470,294 L412,216" />
                <g class="map-node map-node--world">
                  <rect x="248" y="146" width="164" height="70" rx="8" />
                  <text x="330" y="173" class="node-type" text-anchor="middle">Architecture</text>
                  <text x="330" y="195" class="node-name" text-anchor="middle">World Model</text>
                </g>
                <g class="map-node map-node--flow">
                  <rect x="40" y="38" width="150" height="56" rx="6" />
                  <text x="52" y="61" class="node-type">Business flows</text>
                  <text x="52" y="82" class="node-name">ZFL</text>
                </g>
                <g class="map-node map-node--domain">
                  <rect x="255" y="22" width="150" height="56" rx="6" />
                  <text x="267" y="45" class="node-type">Domain model</text>
                  <text x="267" y="66" class="node-name">ZDL</text>
                </g>
                <g class="map-node map-node--api">
                  <rect x="470" y="38" width="150" height="56" rx="6" />
                  <text x="482" y="61" class="node-type">API contracts</text>
                  <text x="482" y="82" class="node-name">OpenAPI</text>
                </g>
                <g class="map-node map-node--event">
                  <rect x="40" y="150" width="150" height="56" rx="6" />
                  <text x="52" y="173" class="node-type">Event contracts</text>
                  <text x="52" y="194" class="node-name">AsyncAPI + Avro</text>
                </g>
                <g class="map-node map-node--vista">
                  <rect x="40" y="266" width="150" height="56" rx="6" />
                  <text x="52" y="289" class="node-type">ZenWave Vistas</text>
                  <text x="52" y="310" class="node-name">EventCatalog</text>
                </g>
                <g class="map-node map-node--service">
                  <rect x="470" y="150" width="150" height="56" rx="6" />
                  <text x="482" y="173" class="node-type">Source code</text>
                  <text x="482" y="194" class="node-name">Spring Boot</text>
                </g>
                <g class="map-node map-node--repo">
                  <rect x="255" y="266" width="150" height="56" rx="6" />
                  <text x="267" y="289" class="node-type">Repositories</text>
                  <text x="267" y="310" class="node-name">Git + folders</text>
                </g>
                <g class="map-node map-node--registry">
                  <rect x="470" y="266" width="150" height="56" rx="6" />
                  <text x="482" y="289" class="node-type">Schema registry</text>
                  <text x="482" y="310" class="node-name">Apicurio</text>
                </g>
              </svg>
            </div>

            <a class="delivery-card" href="/docs/getting-started/" aria-label="Get started with ZenWave SDK">
              <img
                src="/images/laptop-buddha-transparent.png"
                alt=""
                loading="eager"
                decoding="async"
                fetchpriority="high"
                width="958"
                height="1045"
              />
              <div>
                <span>ZenWave SDK</span>
                <p>Generate Spring Boot services, APIs, event adapters, tests, and infrastructure from connected architecture artifacts.</p>
              </div>
            </a>
          </div>
        </div>
      </section>

      <ArchitectureLifecycleBand />

      <section class="home-section" aria-labelledby="platform-title">
        <div class="home-shell">
          <div class="section-heading">
            <p class="eyebrow">ZenWave Platform</p>
            <h2 id="platform-title">What ZenWave Platform Is</h2>
            <p>
              ZenWave Platform is a set of connected capabilities for making the big picture of
              your software explicit, connected, and navigable, from discovery and modeling to
              generation and navigation.
            </p>
          </div>

          <ImageCarousel
            ariaLabel="ZenWave platform screenshots"
            slides={platformScreenshots.map((screenshot) => ({
              src: `/images/platform/screenshots/${screenshot.file}`,
              caption: screenshot.caption,
              alt: screenshot.caption,
              width: screenshot.width,
              height: screenshot.height,
            }))}
          />

          <div class="featured-capabilities">
            {featuredCapabilities.map((card) => (
              <article class:list={['capability-card', 'capability-card--featured', card.variant && `capability-card--${card.variant}`]}>
                <div class="capability-card__media" aria-hidden="true">
                  {card.visual === 'world-model' ? (
                    <div class="world-model-visual">
                      <svg class="world-model-graph" viewBox="0 32 660 218" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
                        <path d="M174,85 L255,85" />
                        <path d="M405,85 L486,85" />
                        <path d="M174,185 L255,185" />
                        <path d="M405,185 L486,185" />
                        <path d="M99,113 L99,157" />
                        <path d="M330,113 L330,157" />
                        <path d="M561,113 L561,157" />
                        <path class="sdk-path" d="M330,113 C350,144 520,152 561,157" />
                        <g class="map-node map-node--flow">
                          <rect x="24" y="57" width="150" height="56" rx="6" />
                          <text x="36" y="80" class="node-type">Business flow</text>
                          <text x="36" y="101" class="node-name">ZFL</text>
                        </g>
                        <g class="map-node map-node--domain">
                          <rect x="255" y="57" width="150" height="56" rx="6" />
                          <text x="267" y="80" class="node-type">Domain model</text>
                          <text x="267" y="101" class="node-name">ZDL</text>
                        </g>
                        <g class="map-node map-node--api">
                          <rect x="486" y="57" width="150" height="56" rx="6" />
                          <text x="498" y="80" class="node-type">Open standard</text>
                          <text x="498" y="101" class="node-name">OpenAPI</text>
                        </g>
                        <g class="map-node map-node--event">
                          <rect x="24" y="157" width="150" height="56" rx="6" />
                          <text x="36" y="180" class="node-type">Event stream</text>
                          <text x="36" y="201" class="node-name">AsyncAPI</text>
                        </g>
                        <g class="map-node map-node--schema">
                          <rect x="255" y="157" width="150" height="56" rx="6" />
                          <text x="267" y="180" class="node-type">Schema</text>
                          <text x="267" y="201" class="node-name">OrderPlaced</text>
                        </g>
                        <g class="map-node map-node--service">
                          <rect x="486" y="157" width="150" height="56" rx="6" />
                          <text x="498" y="180" class="node-type">Service</text>
                          <text x="498" y="201" class="node-name">Spring Boot</text>
                        </g>
                      </svg>
                    </div>
                  ) : (
                    <img src={card.image} alt={card.imageAlt} loading="lazy" decoding="async" width={card.imageWidth} height={card.imageHeight} />
                  )}
                </div>
                <div class="capability-card__body">
                  <div class="capability-card__heading">
                    <h3>{card.title}</h3>
                    <span class={`maturity-badge ${maturityBadgeClass(card.badge)}`}>{card.badge}</span>
                  </div>
                  <p>{card.text}</p>
                  {card.note && <p class="capability-card__note">{card.note}</p>}
                  {card.ctas && (
                    <div class="capability-actions">
                      {card.ctas.map((cta) => (
                        <a class="capability-link" href={cta.href}>{cta.label} <span aria-hidden="true">&#8594;</span></a>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))}
          </div>

          <div class="capability-group">
            <h3>Platform Capabilities</h3>
            <div class="capability-grid" role="list" aria-label="ZenWave platform capabilities">
              {platformCapabilityCards.map((card) => (
                <a class="capability-card capability-card--link" href={card.href} role="listitem">
                  <span class={`maturity-badge ${maturityBadgeClass(card.badge)}`}>{card.badge}</span>
                  <div class="capability-card__icon" aria-hidden="true">
                    {card.image && <img src={card.image} alt="" loading="lazy" decoding="async" width={card.imageWidth} height={card.imageHeight} />}
                  </div>
                  <div class="capability-card__body">
                    <h3>{card.title}</h3>
                    <p>{card.text}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <div class="capability-group">
            <h3>Supporting OSS</h3>
            <div class="capability-grid" role="list" aria-label="ZenWave supporting open source capabilities">
              {supportingCapabilityCards.map((card) => (
                card.href ? (
                  <a class="capability-card capability-card--link" href={card.href} role="listitem">
                    <span class={`maturity-badge ${maturityBadgeClass(card.badge)}`}>{card.badge}</span>
                    <div class="capability-card__icon" aria-hidden="true">
                      <Fragment set:html={supportingCapabilityIcons[card.icon]} />
                    </div>
                    <div class="capability-card__body">
                      <h3>{card.title}</h3>
                      <p>{card.text}</p>
                    </div>
                  </a>
                ) : (
                  <article class="capability-card" role="listitem">
                    <span class={`maturity-badge ${maturityBadgeClass(card.badge)}`}>{card.badge}</span>
                    <div class="capability-card__icon" aria-hidden="true">
                      <Fragment set:html={supportingCapabilityIcons[card.icon]} />
                    </div>
                    <div class="capability-card__body">
                      <h3>{card.title}</h3>
                      <p>{card.text}</p>
                    </div>
                  </article>
                )
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="home-section reference-section" aria-labelledby="reference-title">
        <div class="home-shell">
          <div class="section-heading">
            <p class="eyebrow">Built in public</p>
            <h2 id="reference-title">Reference Architectures</h2>
            <p>
              Examples that show how discovery, domain models, APIs, events, schemas, generated services, and operational concerns work together in realistic systems.
            </p>
          </div>

          <article class="reference-feature">
            <div class="reference-feature__media">
              <img src="/images/reference-architectures/arcadia.png" alt="Arcadia Editions" loading="lazy" decoding="async" width="1254" height="1254" />
            </div>
            <div class="reference-feature__body">
              <span class={`maturity-badge ${maturityBadgeClass('Building in public')}`}>Building in public</span>
              <h3>Arcadia Editions</h3>
              <p>
                A fictional publisher with real product, catalog, order, event, and integration
                pressure.
              </p>
              <p>
                Arcadia is the working example for the ZenWave Platform idea: from Event Storming
                to ZFL flows, contracts, services, events, and AI-assisted delivery.
              </p>
              <div class="actions">
                <a class="button" href="https://ivangsa.com/articles/arcadia/">Read the series</a>
                <a class="button button--secondary" href="https://github.com/arcadia-editions">View the code</a>
              </div>
            </div>
          </article>

          <div class="reference-grid">
            {referenceCards.map((card) => (
              <a class="reference-card" href={card.href}>
                <img src={card.image} alt="" loading="lazy" decoding="async" width={card.imageWidth} height={card.imageHeight} />
                <div class="reference-card__body">
                  <h3>{card.title}</h3>
                  <p>{card.text}</p>
                  <span>{card.cta} <span aria-hidden="true">&#8594;</span></span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section class="home-section closing-band" aria-labelledby="closing-title">
        <div class="home-shell closing-band__inner">
          <p class="eyebrow">Idea Lab</p>
          <div class="closing-band__copy">
            <p id="closing-title">
              I created ZenWave SDK to help me think about software, talk about it, validate it...
              and then generate all the boring parts that were already present in the model.
              Four years in production, open sourced from day one, funded by the time it saved me and my team.
            </p>
            <p>
              The platform, the architectural world model, is where I take this further:
              making the big picture visible and navigable, for people and agents.
            </p>
            <p>If it's useful to you too, let's talk.</p>
          </div>
          <div class="closing-band__footer">
            <p class="closing-band__signature">Iván, building ZenWave Platform</p>
            <a class="button closing-band__button" href="mailto:ivangsa@gmail.com?subject=ZenWave%20Platform">Get in touch</a>
          </div>
        </div>
      </section>

    </main>
    <ZenFooter />
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --home-bg: var(--sl-color-bg, #111318);
    --home-panel: color-mix(in srgb, var(--sl-color-bg-nav, #151820), white 3%);
    --home-panel-strong: #191d25;
    --home-text: var(--sl-color-white, #f3f5f8);
    --home-muted: var(--sl-color-gray-2, #b9c0ca);
    --home-border: var(--sl-color-hairline, #303744);
    --home-highlight: var(--zen-highlight, #ffe04b);
    --home-link: var(--zen-link, #2f81f7);
    --home-shell-width: 1320px;
  }

  :root[data-theme='light'] {
    color-scheme: light;
    --home-bg: #fffaf7;
    --home-panel: #ffffff;
    --home-panel-strong: #fffdfb;
    --home-text: #191713;
    --home-muted: #5f6670;
    --home-border: #e6ded8;
    --home-link: #0969da;
  }

  body {
    margin: 0;
    color: var(--home-text);
    background: var(--home-bg);
    font-family: -apple-system, system-ui, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  a {
    color: inherit;
  }

  .home-shell {
    width: min(var(--home-shell-width), calc(100% - clamp(2rem, 5vw, 4rem)));
    margin-inline: auto;
  }

  .home-hero {
    padding: calc(var(--sl-nav-height, 4rem) + clamp(3rem, 7vw, 6rem)) 0 clamp(3rem, 7vw, 5rem);
    border-bottom: 1px solid var(--home-border);
    background:
      radial-gradient(circle at 88% 12%, color-mix(in srgb, #14a39a 16%, transparent), transparent 28rem),
      linear-gradient(180deg, color-mix(in srgb, var(--home-bg), white 4%), var(--home-bg));
  }

  .home-hero__grid {
    display: grid;
    grid-template-columns: minmax(22rem, 0.85fr) minmax(28rem, 1.15fr);
    gap: clamp(2.25rem, 5vw, 5rem);
    align-items: center;
  }

  .eyebrow {
    margin: 0 0 0.6rem;
    color: var(--home-highlight);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    margin: 0;
    max-width: 30ch;
    color: var(--home-text);
    font-size: clamp(1.7rem, 2vw, 2.2rem);
    font-weight: 600;
    line-height: 1.06;
    letter-spacing: 0;
  }

  .hero-lede {
    max-width: 42rem;
    margin: 1.25rem 0 0;
    color: var(--home-muted);
    font-size: clamp(1.05rem, 2vw, 1.32rem);
    line-height: 1.48;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0 1rem;
    border: 1px solid color-mix(in srgb, var(--home-highlight), transparent 25%);
    border-radius: 0.4rem;
    background: var(--home-highlight);
    color: #1b0d04;
    font-weight: 600;
    line-height: 1.1;
    text-decoration: none;
  }

  .button--secondary {
    border-color: var(--home-border);
    background: var(--home-panel);
    color: var(--home-text);
  }

  .status-line {
    margin: 1rem 0 0;
    color: var(--home-muted);
    font-size: 0.95rem;
  }

  .home-hero__visual {
    position: relative;
    display: grid;
    gap: 0;
    min-height: 0;
  }

  .model-map {
    position: relative;
    min-height: 25rem;
    overflow: hidden;
    border: 1px solid var(--home-border);
    border-radius: 0.5rem;
    background:
      linear-gradient(color-mix(in srgb, var(--home-border), transparent 64%) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--home-border), transparent 64%) 1px, transparent 1px),
      var(--home-panel);
    background-size: 46px 46px;
    box-shadow: 0 1rem 2.5rem rgb(0 0 0 / 0.18);
  }

  :root[data-theme='light'] .model-map {
    box-shadow: 0 1rem 2rem rgb(32 41 58 / 0.08);
  }

  .model-map__header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--home-border);
    color: var(--home-muted);
    font-size: 0.8rem;
  }

  .model-map__graph {
    position: absolute;
    inset: 2.5rem 0 0;
    width: 100%;
    height: calc(100% - 2.5rem);
  }

  .model-map__graph path {
    fill: none;
    stroke: color-mix(in srgb, var(--home-highlight), white 12%);
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-dasharray: 7 9;
    opacity: 0.62;
  }

  .model-map__graph .sdk-path {
    stroke: #14a39a;
    stroke-dasharray: 8 6;
    opacity: 0.8;
    stroke-width: 2.5;
  }

  .model-map__graph .map-node rect {
    fill: color-mix(in srgb, var(--home-panel-strong), var(--node-color) 8%);
    stroke: color-mix(in srgb, var(--node-color), var(--home-border) 42%);
    stroke-width: 1.5;
  }

  .model-map__graph .map-node--flow { --node-color: #f1a13a; }
  .model-map__graph .map-node--domain { --node-color: #14a39a; }
  .model-map__graph .map-node--api { --node-color: #3b75d1; }
  .model-map__graph .map-node--event { --node-color: #55a447; }
  .model-map__graph .map-node--schema { --node-color: #d99100; }
  .model-map__graph .map-node--vista { --node-color: #d99100; }
  .model-map__graph .map-node--service { --node-color: #e05b64; }
  .model-map__graph .map-node--world { --node-color: #ffe04b; }
  .model-map__graph .map-node--repo { --node-color: #8d7cf6; }
  .model-map__graph .map-node--registry { --node-color: #2fb7c9; }

  .model-map__graph .node-type {
    fill: var(--home-muted);
    font-size: 11px;
    font-weight: 600;
    font-family: -apple-system, system-ui, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .model-map__graph .node-name {
    fill: var(--home-text);
    font-size: 16px;
    font-weight: 700;
    font-family: -apple-system, system-ui, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .delivery-card {
    justify-self: center;
    margin-top: -1.25rem;
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 5.5rem minmax(0, 1fr);
    gap: 0.9rem;
    align-items: center;
    width: min(23rem, calc(100% - 2rem));
    padding: 0.9rem;
    border: 1px solid color-mix(in srgb, var(--home-highlight), var(--home-border) 50%);
    border-radius: 0.5rem;
    background: var(--home-panel-strong);
    box-shadow: 0 1rem 2rem rgb(0 0 0 / 0.22);
    text-decoration: none;
    transition:
      border-color 160ms ease,
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .delivery-card:hover,
  .delivery-card:focus-visible {
    border-color: var(--home-highlight);
    transform: translateY(-1px);
    box-shadow: 0 1.2rem 2.2rem rgb(0 0 0 / 0.28);
    outline: none;
  }

  :root[data-theme='light'] .delivery-card {
    background: #ffffff;
    box-shadow: 0 1rem 2rem rgb(32 41 58 / 0.1);
  }

  .delivery-card img {
    width: 5.5rem;
    height: 5.5rem;
    object-fit: contain;
  }

  .delivery-card span,
  .delivery-card p {
    color: var(--home-muted);
  }

  .delivery-card span {
    color: var(--home-text);
    font-weight: 600;
  }

  .delivery-card strong {
    display: block;
    margin: 0.1rem 0 0.25rem;
    color: var(--home-text);
    font-size: 1.05rem;
  }

  .delivery-card p {
    margin: 0.15rem 0 0;
    font-size: 0.86rem;
    line-height: 1.4;
  }

  .section-heading p {
    margin: 0;
    color: var(--home-muted);
    line-height: 1.58;
  }

  .home-section {
    position: relative;
    padding: clamp(2rem, 3vw, 2.75rem) 0 clamp(1.4rem, 2.5vw, 2.2rem);
  }

  .home-section + .home-section {
    border-top: 1px solid color-mix(in srgb, var(--home-border), transparent 30%);
  }

  .section-heading {
    margin-bottom: 1rem;
  }

  .section-heading--maturity {
    margin-top: 1rem;
  }

  .section-heading h2 {
    margin: 0 0 0.75rem;
    color: var(--home-text);
    font-size: clamp(1.55rem, 2.35vw, 2.05rem);
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: 0;
  }

  .section-heading p:not(.eyebrow) {
    max-width: 58rem;
  }

  .featured-capabilities {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(22rem, 1fr);
    gap: 1rem;
    margin-top: 1.2rem;
  }

  .capability-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 0.75rem;
  }

  .capability-group {
    margin-top: 1.2rem;
  }

  .capability-group h3 {
    margin: 0;
    color: var(--home-text);
    font-size: clamp(1.15rem, 1.8vw, 1.35rem);
    line-height: 1.2;
  }

  .capability-card {
    position: relative;
    display: grid;
    align-content: start;
    gap: 1rem;
    min-height: 14.5rem;
    padding: 1.15rem;
    border: 1px solid var(--home-border);
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--home-panel), var(--home-panel-strong) 44%);
    box-shadow: 0 0.8rem 1.5rem rgb(0 0 0 / 0.12);
  }

  .capability-card--link {
    color: inherit;
    text-decoration: none;
    transition:
      border-color 160ms ease,
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .capability-card--link:hover,
  .capability-card--link:focus-visible {
    border-color: color-mix(in srgb, var(--home-highlight), var(--home-border) 30%);
    transform: translateY(-1px);
    box-shadow: 0 1rem 2rem rgb(0 0 0 / 0.16);
    outline: none;
  }

  .capability-card > .maturity-badge {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
  }

  .capability-card--featured {
    grid-template-columns: minmax(7rem, 0.35fr) minmax(0, 0.65fr);
    align-items: center;
    min-height: 18rem;
    border-color: color-mix(in srgb, var(--home-highlight), var(--home-border) 54%);
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--home-highlight), transparent 93%), transparent 42%),
      var(--home-panel);
  }

  .capability-card--world-model {
    grid-template-columns: 1fr;
  }

  .capability-card--sdk {
    grid-template-columns: 1fr;
    justify-items: center;
    text-align: left;
    background:
      linear-gradient(135deg, color-mix(in srgb, #14a39a, transparent 90%), transparent 46%),
      var(--home-panel);
  }

  .capability-card__media {
    display: grid;
    place-items: center;
    min-height: 12rem;
  }

  .capability-card__media img {
    width: min(100%, 10rem);
    height: auto;
    object-fit: contain;
  }

  .capability-card--sdk .capability-card__media img {
    width: min(100%, 11rem);
  }

  .capability-card--sdk .capability-card__media {
    min-height: 10rem;
  }

  .world-model-visual {
    width: 100%;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--home-border), transparent 20%);
    border-radius: 0.45rem;
    background:
      linear-gradient(color-mix(in srgb, var(--home-border), transparent 68%) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--home-border), transparent 68%) 1px, transparent 1px),
      color-mix(in srgb, var(--home-panel-strong), var(--home-panel) 30%);
    background-size: 38px 38px;
  }

  .capability-card--world-model .world-model-visual {
    display: grid;
    place-items: center;
    height: 12.5rem;
  }

  .world-model-visual svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .world-model-graph {
    display: block;
    width: 100%;
    height: 100%;
  }

  .world-model-graph path {
    fill: none;
    stroke: color-mix(in srgb, var(--home-highlight), white 12%);
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-dasharray: 7 9;
    opacity: 0.62;
  }

  .world-model-graph .sdk-path {
    stroke: #14a39a;
    stroke-dasharray: 8 6;
    opacity: 0.8;
    stroke-width: 2.5;
  }

  .world-model-graph .map-node rect {
    fill: color-mix(in srgb, var(--home-panel-strong), var(--node-color) 8%);
    stroke: color-mix(in srgb, var(--node-color), var(--home-border) 42%);
    stroke-width: 1.5;
  }

  .world-model-graph .map-node--flow { --node-color: #f1a13a; }
  .world-model-graph .map-node--domain { --node-color: #14a39a; }
  .world-model-graph .map-node--api { --node-color: #3b75d1; }
  .world-model-graph .map-node--event { --node-color: #55a447; }
  .world-model-graph .map-node--schema { --node-color: #d99100; }
  .world-model-graph .map-node--service { --node-color: #e05b64; }

  .world-model-graph .node-type {
    fill: var(--home-muted);
    font-size: 11px;
    font-weight: 600;
    font-family: -apple-system, system-ui, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .world-model-graph .node-name {
    fill: var(--home-text);
    font-size: 16px;
    font-weight: 700;
    font-family: -apple-system, system-ui, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .capability-card__icon {
    display: grid;
    place-items: center;
    width: 3.4rem;
    aspect-ratio: 1;
    margin-inline: auto;
    color: var(--home-highlight);
  }

  .capability-card__icon img {
    width: 3rem;
    height: 3rem;
    object-fit: contain;
  }

  .capability-card__icon svg {
    width: 2.8rem;
    height: 2.8rem;
    color: var(--home-highlight);
  }

  .capability-card__icon svg :where(path, rect) {
    fill: none;
    stroke: currentColor;
    stroke-width: 3.4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .capability-card__icon .schema-mark {
    width: 3rem;
  }

  .capability-card__body {
    display: grid;
    gap: 0.65rem;
    min-width: 0;
    grid-template-rows: auto 1fr auto;
  }

  .capability-card__heading {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
    justify-content: space-between;
  }

  .capability-card h3 {
    margin: 0;
    color: var(--home-text);
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    line-height: 1.15;
  }

  .capability-card p {
    margin: 0;
    color: var(--home-muted);
    line-height: 1.55;
  }

  .capability-card__note {
    color: var(--home-text) !important;
    font-weight: 600;
  }

  .capability-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
  }

  .maturity-badge {
    --badge-color: var(--home-highlight);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    width: fit-content;
    padding: 0;
    border: none;
    background: none;
    color: color-mix(in srgb, var(--home-text), transparent 25%);
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.1;
  }

  .maturity-badge::before {
    content: '';
    flex-shrink: 0;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background: var(--badge-color);
  }

  .maturity-badge--production {
    --badge-color: #4caf50;
  }

  .maturity-badge--building {
    --badge-color: #d99100;
  }

  .maturity-badge--emerging {
    --badge-color: #7890ad;
  }

  .maturity-badge--supporting {
    --badge-color: #18b7aa;
  }

  .capability-link {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 2.25rem;
    margin-top: 0.15rem;
    padding: 0 0.8rem;
    border: 1px solid color-mix(in srgb, var(--home-highlight), transparent 25%);
    border-radius: 0.4rem;
    background: var(--home-highlight);
    color: #1b0d04;
    font-weight: 700;
    line-height: 1.1;
    text-decoration: none;
  }

  .reference-section {
    background:
      linear-gradient(90deg, color-mix(in srgb, #14a39a 8%, transparent), transparent 52%),
      var(--home-bg);
  }

  .reference-feature {
    display: grid;
    grid-template-columns: minmax(15rem, 0.42fr) minmax(0, 0.58fr);
    gap: clamp(1.25rem, 4vw, 2.5rem);
    align-items: center;
    margin-top: 1rem;
    padding: 1rem;
    border: 1px solid var(--home-border);
    border-radius: 0.5rem;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--home-highlight), transparent 94%), transparent 40%),
      var(--home-panel);
  }

  .reference-feature__media {
    display: grid;
    place-items: center;
    min-height: 14rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--home-border), transparent 20%);
    border-radius: 0.45rem;
    background: #ffffff;
  }

  .reference-feature__media img {
    width: 100%;
    height: 100%;
    max-height: 18rem;
    object-fit: contain;
  }

  .reference-feature__body {
    display: grid;
    gap: 0.75rem;
    min-width: 0;
  }

  .reference-feature h3 {
    margin: 0;
    color: var(--home-text);
    font-size: clamp(1.55rem, 2.35vw, 2.05rem);
    line-height: 1.12;
  }

  .reference-feature p {
    margin: 0;
    color: var(--home-muted);
    line-height: 1.58;
  }

  .reference-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .reference-card {
    display: grid;
    min-height: 100%;
    overflow: hidden;
    border: 1px solid var(--home-border);
    border-radius: 0.5rem;
    background: var(--home-panel);
    color: inherit;
    text-decoration: none;
  }

  .reference-card img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    height: auto;
    object-fit: contain;
    padding: 0.65rem;
    border-bottom: 1px solid var(--home-border);
    background: color-mix(in srgb, var(--home-panel-strong), white 5%);
  }

  .reference-card__body {
    display: grid;
    align-content: start;
    gap: 0.55rem;
    padding: 1rem;
  }

  .reference-card h3 {
    margin: 0;
    color: var(--home-text);
    font-size: 1.05rem;
    line-height: 1.2;
  }

  .reference-card p {
    margin: 0;
    color: var(--home-muted);
    line-height: 1.48;
  }

  .reference-card__body > span {
    margin-top: 0.25rem;
    color: var(--home-highlight);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .closing-band {
    position: relative;
    padding: clamp(2.75rem, 5vw, 4.5rem) 0 clamp(3rem, 6vw, 5rem);
    border-top: 1px solid color-mix(in srgb, var(--home-border), transparent 25%);
    overflow: hidden;
  }

  .closing-band::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(color-mix(in srgb, var(--home-border), transparent 84%) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--home-border), transparent 84%) 1px, transparent 1px);
    background-size: 42px 42px;
    opacity: 0.22;
    mask-image: linear-gradient(180deg, transparent, #000 22%, #000 72%, transparent);
  }

  .closing-band__inner {
    position: relative;
    width: min(660px, calc(100% - clamp(2rem, 5vw, 4rem)));
    margin-inline: auto;
  }

  .closing-band__inner::before {
    content: '';
    display: block;
    width: 4rem;
    margin-bottom: 1.05rem;
    border-top: 1px solid color-mix(in srgb, var(--home-highlight), transparent 35%);
  }

  .closing-band__copy {
    display: grid;
    gap: 1rem;
    margin-top: 0.85rem;
  }

  .closing-band__copy p {
    margin: 0;
    color: color-mix(in srgb, var(--home-text), var(--home-muted) 18%);
    font-size: clamp(1.02rem, 1.35vw, 1.16rem);
    font-style: oblique 8deg;
    font-synthesis-style: auto;
    font-weight: 400;
    line-height: 1.58;
  }

  .closing-band__footer {
    display: grid;
    justify-items: start;
    gap: 1.05rem;
    margin-top: 1.5rem;
  }

  .closing-band__signature {
    margin: 0;
    color: color-mix(in srgb, var(--home-text), var(--home-muted) 8%);
    font-size: 0.98rem;
    font-style: normal;
    font-weight: 400;
    text-align: left;
  }

  .closing-band__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    margin-top: 0;
    padding: 0 1rem;
    border: 1px solid color-mix(in srgb, var(--home-highlight), transparent 25%);
    border-radius: 0.4rem;
    background: var(--home-highlight);
    color: #1b0d04;
    font-weight: 700;
    line-height: 1.1;
    text-decoration: none;
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      transform 160ms ease;
  }

  .closing-band__button:hover,
  .closing-band__button:focus-visible {
    border-color: var(--home-highlight);
    background: color-mix(in srgb, var(--home-highlight), white 8%);
    transform: translateY(-1px);
    outline: none;
  }

  @media (max-width: 960px) {
    .home-hero__grid,
    .reference-feature {
      grid-template-columns: 1fr;
    }

    h1 {
      max-width: 18ch;
    }

    .capability-grid,
    .reference-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .featured-capabilities {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
